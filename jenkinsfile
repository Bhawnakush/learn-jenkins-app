pipeline {
    agent any

    stages {
        stage('build') {
            agent{
                docker{
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps {
                echo 'Hello World this is bhawna kushwaha'
                sh '''
                ls -la
                node --version
                npm --version
                npm ci
                ls -la 
                npm run build '''
            }
        }
       stage('Test'){
         agent{
                docker{
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps{
                sh ''' 
                test -f build/index.html
                npm test
                '''
            }
       }

    }

}
